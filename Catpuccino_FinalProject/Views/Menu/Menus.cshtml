@using System.Linq
@model IEnumerable<Catpuccino_FinalProject.Models.Product>

@{
    ViewData["Title"] = "Menus";
}

<link rel="stylesheet" href="~/css/menu.css" asp-append-version="true" />

<header class="menu-hero">
    <div class="container d-flex justify-content-between align-items-center">
        <h1 class="menu-title">Our Menu</h1>

        <div class="position-relative">
            <button class="btn btn-order-main" data-bs-toggle="modal" data-bs-target="#orderModal">
                Order <span class="notification-dot" style="display: none;"></span>
            </button>
        </div>
    </div>
</header>

<div class="container text-center mt-5">
    <div class="search-container">
        <input type="text" id="menuSearch" class="form-control search-input" placeholder="Search drinks, pastries, snacks">
    </div>

    <div class="d-flex justify-content-center flex-wrap mb-5">
        <button class="filter-btn  active">All Items</button>
        <button class="filter-btn">Coffee</button>
        <button class="filter-btn">Tea</button>
        <button class="filter-btn">Pastries</button>
        <button class="filter-btn">Cakes</button>
    </div>
</div>

<main class="container mb-5">
    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col product-item" data-category="@item.Category.ToLower()">
                    <div class="card menu-card h-100" style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#modal-@item.Id">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 220px; object-fit: cover;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-brown fw-bold">@item.Name</h5>
                            <p class="card-text small text-muted flex-grow-1">@item.Description</p>
                            <p class="fw-bold text-brown mb-0 fs-5">P @item.Price.ToString("0")</p>
                        </div>
                    </div>
                </div>

                <div class="modal fade product-detail-modal" id="modal-@item.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content modal-content-custom shadow-lg p-0">

                            <img src="@item.ImageUrl" class="w-100" style="height: 250px; object-fit: cover; border-top-left-radius: 30px; border-top-right-radius: 30px;" />

                            <div class="p-4">
                                <h3 class="text-brown fw-bold mb-1 product-name-display">@item.Name</h3>
                                <p class="small text-muted mb-4">@item.Description</p>

                                <form id="form-@item.Id">
                                    <input type="hidden" name="ProductId" value="@item.Id" />

                                    <h5 class="text-brown fw-bold mb-3">Size</h5>

                                    <div class="d-flex gap-2 mb-4 size-selector-group">
                                        <input type="radio" id="small-@item.Id" name="Size" value="Small" class="d-none size-radio" data-addon="0" checked>
                                        <label for="small-@item.Id" class="btn-size-label text-center">
                                            <span class="fw-bold d-block">Small</span>
                                            <span class="small">Base</span>
                                        </label>

                                        <input type="radio" id="medium-@item.Id" name="Size" value="Medium" class="d-none size-radio" data-addon="20">
                                        <label for="medium-@item.Id" class="btn-size-label text-center">
                                            <span class="fw-bold d-block">Medium</span>
                                            <span class="small">+P20</span>
                                        </label>

                                        <input type="radio" id="large-@item.Id" name="Size" value="Large" class="d-none size-radio" data-addon="40">
                                        <label for="large-@item.Id" class="btn-size-label text-center">
                                            <span class="fw-bold d-block">Large</span>
                                            <span class="small">+P40</span>
                                        </label>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-end mb-4">
                                        <div>
                                            <h5 class="text-brown fw-bold mb-2">Quantity</h5>
                                            <div class="d-flex align-items-center gap-3">
                                                <button type="button" class="btn-qty minus-btn" data-target="@item.Id">-</button>
                                                <input type="hidden" name="Quantity" id="qty-input-@item.Id" value="1" />
                                                <span id="qty-text-@item.Id" class="fs-4 fw-bold text-brown">1</span>
                                                <button type="button" class="btn-qty plus-btn" data-target="@item.Id">+</button>
                                            </div>
                                        </div>
                                        <div>
                                            <span class="fs-5 fw-bold text-brown">Total : P<span class="live-total" id="total-@item.Id" data-baseprice="@item.Price">@item.Price.ToString("0")</span></span>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-3 mt-2">
                                        <button type="button" class="btn btn-cancel flex-grow-1" data-bs-dismiss="modal">Cancel</button>
                                        <button type="button" class="btn btn-add-to-order flex-grow-1 add-to-cart-btn">Add to Order</button>
                                    </div>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center empty-state">
            <img src="~/images/menupics/waitorderillus.png" style="width: 500px;" class="mb-3" />
        </div>
    }
</main>

<!-- ORDER MODAL -->
<div class="modal fade" id="orderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom shadow-lg">

            <div class="modal-header modal-header-custom border-0 d-flex justify-content-between">
                <h5 class="modal-title modal-title-custom">Your Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-0">
                <div id="cartItemsContainer">
                    <p class="text-center text-muted py-5 italic">Your cart is currently empty.</p>
                </div>

                <div class="order-totals">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-brown">Subtotal</span>
                        <span class="text-brown" id="cart-subtotal">P0</span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold fs-4">
                        <span>Total</span>
                        <span id="cart-total">P0</span>
                    </div>
                </div>

                <button class="btn btn-place-order shadow-sm w-100 mt-4">Place Order</button>
            </div>

        </div>
    </div>
</div>

<!-- PAYMENT MODAL -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom shadow-lg">

            <div class="modal-header modal-header-custom border-0 d-flex justify-content-between">
                <h5 class="modal-title modal-title-custom">Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-0">

                <!-- Step 1: Select Payment Method -->
                <div class="px-3 pb-3" id="step-select-method">
                    <p class="text-muted small fw-bold mb-2">SELECT PAYMENT METHOD</p>

                    <div class="d-flex flex-column gap-2 mb-4">

                        <label class="payment-method-option d-flex align-items-center gap-3 p-3 rounded-4 border" style="cursor: pointer;">
                            <input type="radio" name="paymentMethod" value="Maya" class="d-none pay-radio" />
                            <div style="background:#E8F0FE; color:#1A56DB; width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:16px; flex-shrink:0;">M</div>
                            <div class="flex-grow-1">
                                <div class="fw-bold text-brown">Maya</div>
                                <div class="text-muted small">Pay via Maya e-wallet</div>
                            </div>
                            <div class="pay-radio-dot" style="width:18px; height:18px; border-radius:50%; border:1.5px solid #ccc; flex-shrink:0;"></div>
                        </label>

                        <label class="payment-method-option d-flex align-items-center gap-3 p-3 rounded-4 border" style="cursor: pointer;">
                            <input type="radio" name="paymentMethod" value="GCash" class="d-none pay-radio" />
                            <div style="background:#E6F0FF; color:#0070E0; width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:16px; flex-shrink:0;">G</div>
                            <div class="flex-grow-1">
                                <div class="fw-bold text-brown">GCash</div>
                                <div class="text-muted small">Pay via GCash e-wallet</div>
                            </div>
                            <div class="pay-radio-dot" style="width:18px; height:18px; border-radius:50%; border:1.5px solid #ccc; flex-shrink:0;"></div>
                        </label>

                        <label class="payment-method-option d-flex align-items-center gap-3 p-3 rounded-4 border" style="cursor: pointer;">
                            <input type="radio" name="paymentMethod" value="Cash" class="d-none pay-radio" />
                            <div style="background:#EAF3DE; color:#3B6D11; width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;">₱</div>
                            <div class="flex-grow-1">
                                <div class="fw-bold text-brown">Cash</div>
                                <div class="text-muted small">Pay at the counter</div>
                            </div>
                            <div class="pay-radio-dot" style="width:18px; height:18px; border-radius:50%; border:1.5px solid #ccc; flex-shrink:0;"></div>
                        </label>

                    </div>

                    <button class="btn btn-place-order shadow-sm w-100 mb-2" id="proceedToDetailsBtn">Next →</button>
                    <button class="btn btn-cancel w-100" id="backToOrderBtn">← Back to Order</button>
                </div>

                <!-- Step 2: Enter Payment Details -->
                <div class="px-3 pb-3" id="step-enter-details" style="display:none;">

                    <!-- Maya Details -->
                    <div id="details-Maya" class="payment-details-form" style="display:none;">
                        <p class="text-muted small fw-bold mb-3">MAYA DETAILS</p>
                        <div class="mb-3">
                            <label class="form-label text-brown fw-bold small">Account Name</label>
                            <input type="text" class="form-control rounded-3" id="maya-account-name" placeholder="e.g. Juan Dela Cruz" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-brown fw-bold small">Maya Mobile Number</label>
                            <input type="tel" class="form-control rounded-3" id="maya-mobile" placeholder="e.g. 09XXXXXXXXX" maxlength="11" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-brown fw-bold small">Reference Number</label>
                            <input type="text" class="form-control rounded-3" id="maya-ref" placeholder="e.g. 123456789012" maxlength="20" />
                        </div>
                    </div>

                    <!-- GCash Details -->
                    <div id="details-GCash" class="payment-details-form" style="display:none;">
                        <p class="text-muted small fw-bold mb-3">GCASH DETAILS</p>
                        <div class="mb-3">
                            <label class="form-label text-brown fw-bold small">Account Name</label>
                            <input type="text" class="form-control rounded-3" id="gcash-account-name" placeholder="e.g. Juan Dela Cruz" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-brown fw-bold small">GCash Mobile Number</label>
                            <input type="tel" class="form-control rounded-3" id="gcash-mobile" placeholder="e.g. 09XXXXXXXXX" maxlength="11" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-brown fw-bold small">Reference Number</label>
                            <input type="text" class="form-control rounded-3" id="gcash-ref" placeholder="e.g. 123456789012" maxlength="20" />
                        </div>
                    </div>

                    <!-- Cash Details -->
                    <div id="details-Cash" class="payment-details-form" style="display:none;">
                        <p class="text-muted small fw-bold mb-3">CASH PAYMENT</p>
                        <div class="mb-3">
                            <label class="form-label text-brown fw-bold small">Your Name</label>
                            <input type="text" class="form-control rounded-3" id="cash-name" placeholder="e.g. Juan Dela Cruz" />
                        </div>
                        <div class="alert rounded-3 mb-4" style="background:#EAF3DE; border:1px solid #C0DD97;">
                            <div class="fw-bold text-brown small mb-1">📋 Instructions</div>
                            <div class="text-muted small">Please proceed to the cashier to complete your payment. Have the exact amount ready.</div>
                        </div>
                    </div>

                    <button class="btn btn-place-order shadow-sm w-100 mb-2" id="confirmPaymentBtn">Confirm Payment</button>
                    <button class="btn btn-cancel w-100" id="backToMethodBtn">← Back to Payment Methods</button>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        // --- 1. PRODUCT MODAL LOGIC (Plus/Minus & Size Math) ---
        document.querySelectorAll('.btn-qty').forEach(btn => {
            btn.addEventListener('click', function () {
                const targetId = this.getAttribute('data-target');
                const inputEl = document.getElementById('qty-input-' + targetId);
                const textEl = document.getElementById('qty-text-' + targetId);
                let currentVal = parseInt(inputEl.value);

                if (this.classList.contains('minus-btn') && currentVal > 1) {
                    currentVal--;
                } else if (this.classList.contains('plus-btn')) {
                    currentVal++;
                }

                inputEl.value = currentVal;
                textEl.textContent = currentVal;
                updateTotal(targetId);
            });
        });

        document.querySelectorAll('.size-radio').forEach(radio => {
            radio.addEventListener('change', function () {
                const targetId = this.id.split('-')[1];
                updateTotal(targetId);
            });
        });

        function updateTotal(itemId) {
            const qty = parseInt(document.getElementById('qty-input-' + itemId).value);
            const basePrice = parseFloat(document.getElementById('total-' + itemId).getAttribute('data-baseprice'));

            let addon = 0;
            const selectedRadio = document.querySelector(`input[name="Size"][id$="-${itemId}"]:checked`);
            if (selectedRadio) {
                addon = parseFloat(selectedRadio.getAttribute('data-addon'));
            }

            const total = (basePrice + addon) * qty;
            document.getElementById('total-' + itemId).textContent = total;
        }


        // --- 2. DYNAMIC CART LOGIC ---
        let cart = [];

        document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const form = this.closest('form');
                const productId = form.querySelector('input[name="ProductId"]').value;
                const name = this.closest('.p-4').querySelector('.product-name-display').innerText;
                const qty = parseInt(form.querySelector('input[name="Quantity"]').value);

                const selectedRadio = form.querySelector('input[name="Size"]:checked');
                const size = selectedRadio.value;
                const sizeAddon = parseFloat(selectedRadio.getAttribute('data-addon'));
                const basePrice = parseFloat(form.querySelector('.live-total').getAttribute('data-baseprice'));
                const unitPrice = basePrice + sizeAddon;

                const existingIndex = cart.findIndex(item => item.id === productId && item.size === size);
                if (existingIndex > -1) {
                    cart[existingIndex].qty += qty;
                } else {
                    cart.push({ id: productId, name: name, size: size, price: unitPrice, qty: qty });
                }

                const modalEl = this.closest('.modal');
                const bsModal = bootstrap.Modal.getInstance(modalEl);
                bsModal.hide();

                renderCart();
            });
        });

        function renderCart() {
            const container = document.getElementById('cartItemsContainer');
            const subtotalEl = document.getElementById('cart-subtotal');
            const totalEl = document.getElementById('cart-total');
            const notifDot = document.querySelector('.notification-dot');

            if (cart.length === 0) {
                container.innerHTML = '<p class="text-center text-muted py-5 italic">Your cart is currently empty.</p>';
                subtotalEl.innerText = 'P0';
                totalEl.innerText = 'P0';
                if (notifDot) notifDot.style.display = 'none';
                return;
            }

            if (notifDot) notifDot.style.display = 'block';
            let html = '';
            let grandTotal = 0;

            cart.forEach((item, index) => {
                const itemTotal = item.price * item.qty;
                grandTotal += itemTotal;

                html += `
                        <div class="cart-item-card bg-white p-3 rounded-4 mb-3 shadow-sm">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <div>
                                    <h5 class="mb-0 fw-bold text-brown">${item.name}</h5>
                                    <small class="text-muted d-block mt-1">${item.size}</small>
                                </div>
                                <span class="fw-bold text-brown fs-5">P${itemTotal}</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div class="d-flex align-items-center gap-3">
                                    <button type="button" class="btn-circle cart-minus" data-index="${index}">-</button>
                                    <span class="fw-bold text-brown fs-5">${item.qty}</span>
                                    <button type="button" class="btn-circle cart-plus" data-index="${index}">+</button>
                                </div>
                                <button type="button" class="btn-remove-item text-danger fw-bold fs-3 border-0 bg-transparent" data-index="${index}">×</button>
                            </div>
                        </div>
                    `;
            });

            container.innerHTML = html;
            subtotalEl.innerText = 'P' + grandTotal;
            totalEl.innerText = 'P' + grandTotal;
        }

        document.getElementById('cartItemsContainer').addEventListener('click', function (e) {
            if (e.target.classList.contains('cart-minus')) {
                const index = e.target.getAttribute('data-index');
                if (cart[index].qty > 1) {
                    cart[index].qty--;
                } else {
                    cart.splice(index, 1);
                }
                renderCart();
            } else if (e.target.classList.contains('cart-plus')) {
                const index = e.target.getAttribute('data-index');
                cart[index].qty++;
                renderCart();
            } else if (e.target.classList.contains('btn-remove-item')) {
                const index = e.target.getAttribute('data-index');
                cart.splice(index, 1);
                renderCart();
            }
        });


        // --- 3. PLACE ORDER → OPEN PAYMENT MODAL ---
        const placeOrderBtn = document.querySelector('.btn-place-order');
        if (placeOrderBtn) {
            placeOrderBtn.addEventListener('click', function () {
                if (cart.length === 0) {
                    alert("Your cart is empty!");
                    return;
                }

                // Reset to Step 1
                showStep('select-method');
                resetPaymentMethodSelection();

                // Hide order modal, show payment modal
                bootstrap.Modal.getInstance(document.getElementById('orderModal')).hide();
                setTimeout(() => {
                    new bootstrap.Modal(document.getElementById('paymentModal')).show();
                }, 350);
            });
        }


        // --- 4. PAYMENT METHOD VISUAL SELECTION ---
        document.querySelectorAll('.payment-method-option').forEach(opt => {
            opt.addEventListener('click', function () {
                resetPaymentMethodSelection();
                this.style.borderColor = '#5C3A1E';
                const dot = this.querySelector('.pay-radio-dot');
                dot.style.borderColor = '#5C3A1E';
                dot.style.background = '#5C3A1E';
                dot.innerHTML = '<div style="width:7px;height:7px;border-radius:50%;background:#fff;margin:auto;margin-top:4px;"></div>';
                this.querySelector('.pay-radio').checked = true;
            });
        });

        function resetPaymentMethodSelection() {
            document.querySelectorAll('.payment-method-option').forEach(o => {
                o.style.borderColor = '';
                const d = o.querySelector('.pay-radio-dot');
                d.style.borderColor = '#ccc';
                d.style.background = '';
                d.innerHTML = '';
            });
            document.querySelectorAll('.pay-radio').forEach(r => r.checked = false);
        }

        function showStep(stepName) {
            document.getElementById('step-select-method').style.display = 'none';
            document.getElementById('step-enter-details').style.display = 'none';
            document.getElementById('step-' + stepName).style.display = 'block';
        }


        // --- 5. NEXT → SHOW DETAILS FORM ---
        document.getElementById('proceedToDetailsBtn').addEventListener('click', function () {
            const selectedMethod = document.querySelector('.pay-radio:checked');
            if (!selectedMethod) {
                alert("Please select a payment method.");
                return;
            }

            // Hide all detail forms, show the matching one
            document.querySelectorAll('.payment-details-form').forEach(f => f.style.display = 'none');
            document.getElementById('details-' + selectedMethod.value).style.display = 'block';

            // Clear all input fields
            document.querySelectorAll('.payment-details-form input[type="text"], .payment-details-form input[type="tel"]').forEach(input => {
                input.value = '';
            });

            showStep('enter-details');
        });


        // --- 6. BACK TO METHOD SELECTION ---
        document.getElementById('backToMethodBtn').addEventListener('click', function () {
            showStep('select-method');
        });


        // --- 7. BACK TO ORDER MODAL ---
        document.getElementById('backToOrderBtn').addEventListener('click', function () {
            bootstrap.Modal.getInstance(document.getElementById('paymentModal')).hide();
            setTimeout(() => {
                new bootstrap.Modal(document.getElementById('orderModal')).show();
            }, 350);
        });


        // --- 8. CONFIRM PAYMENT → VALIDATE & SUBMIT ---
        document.getElementById('confirmPaymentBtn').addEventListener('click', function () {
            const selectedMethod = document.querySelector('.pay-radio:checked');
            if (!selectedMethod) return;

            const method = selectedMethod.value;
            let paymentDetails = {};

            // Validate fields based on method
            if (method === 'Maya') {
                const name = document.getElementById('maya-account-name').value.trim();
                const mobile = document.getElementById('maya-mobile').value.trim();
                const ref = document.getElementById('maya-ref').value.trim();

                if (!name || !mobile || !ref) {
                    alert("Please fill in all Maya payment details.");
                    return;
                }
                if (!/^09\d{9}$/.test(mobile)) {
                    alert("Please enter a valid Maya mobile number (e.g. 09XXXXXXXXX).");
                    return;
                }
                paymentDetails = { accountName: name, mobileNumber: mobile, referenceNumber: ref };

            } else if (method === 'GCash') {
                const name = document.getElementById('gcash-account-name').value.trim();
                const mobile = document.getElementById('gcash-mobile').value.trim();
                const ref = document.getElementById('gcash-ref').value.trim();

                if (!name || !mobile || !ref) {
                    alert("Please fill in all GCash payment details.");
                    return;
                }
                if (!/^09\d{9}$/.test(mobile)) {
                    alert("Please enter a valid GCash mobile number (e.g. 09XXXXXXXXX).");
                    return;
                }
                paymentDetails = { accountName: name, mobileNumber: mobile, referenceNumber: ref };

            } else if (method === 'Cash') {
                const name = document.getElementById('cash-name').value.trim();
                if (!name) {
                    alert("Please enter your name.");
                    return;
                }
                paymentDetails = { customerName: name };
            }

            this.innerText = "Processing...";
            this.disabled = true;

            const payload = cart.map(item => ({ ...item, paymentMethod: method, paymentDetails: paymentDetails }));

            fetch('@Url.Action("PlaceOrder", "Order")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
                .then(response => {
                    if (!response.ok) throw new Error("Network response was not ok");
                    return response.json();
                })
                .then(data => {
                    if (data.success) {
                        window.location.href = data.redirectUrl;
                    } else {
                        alert("Failed to place order.");
                        this.innerText = "Confirm Payment";
                        this.disabled = false;
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert("An error occurred while communicating with the server.");
                    this.innerText = "Confirm Payment";
                    this.disabled = false;
                });
        });


        // --- 9. FILTER & SEARCH LOGIC ---
        const filterButtons = document.querySelectorAll('.filter-btn');
        const searchInput = document.getElementById('menuSearch');
        const productItems = document.querySelectorAll('.product-item');

        function applyFilters() {
            const activeBtn = document.querySelector('.filter-btn.active');
            const selectedCategory = activeBtn.innerText.toLowerCase().trim();
            const searchTerm = searchInput.value.toLowerCase().trim();

            productItems.forEach(item => {
                const itemCategory = item.getAttribute('data-category');
                const productName = item.querySelector('.card-title').innerText.toLowerCase();
                const productDesc = item.querySelector('.card-text').innerText.toLowerCase();

                const matchesCategory = (selectedCategory === "all items" || itemCategory === selectedCategory);
                const matchesSearch = (productName.includes(searchTerm) || productDesc.includes(searchTerm));

                if (matchesCategory && matchesSearch) {
                    item.style.display = "";
                } else {
                    item.style.display = "none";
                }
            });
        }

        filterButtons.forEach(btn => {
            btn.addEventListener('click', function () {
                filterButtons.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                applyFilters();
            });
        });

        searchInput.addEventListener('keyup', applyFilters);
    });
</script>
